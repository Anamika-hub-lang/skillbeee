# Copy to `.env` for local development (never commit real secrets).

# --- Expo (public, bundled) ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Dashboard → Authentication → Providers: enable Email (password sign-up / login in the app).
#
# Password reset / magic links: add Redirect URLs (Authentication → URL configuration) so the email
# link can open the app instead of localhost on a phone, e.g.:
#   skillbee://auth/callback
# If `expo-linking` prints a non-localhost URL in dev (e.g. exp://192.168.x.x:8081/--/auth/callback), add that too.

# --- Prisma CLI (schema push / migrate; use Supabase Postgres URLs) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DIRECT_URL=

# Optional override if you use a non-default public bucket name for samples + profile photos.
APPLICATION_SAMPLES_BUCKET=

# After schema changes: `npm run db:push` (or migrate).
# Run `supabase/sql/004_client_supabase_only.sql` in the Supabase SQL editor for RLS + RPCs used by the app.

# --- Razorpay (test or live) ---
# Public key — bundled into Expo (restart Metro after changing).
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
# Secret — Supabase Edge Function secrets only (Dashboard → Edge Functions → Secrets, or `supabase secrets set`).
# Do NOT prefix with EXPO_PUBLIC_. Local `supabase functions serve` reads these from your linked project secrets.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Deploy payment functions once per project:
#   supabase functions deploy razorpay-create-order
#   supabase functions deploy razorpay-verify-payment
